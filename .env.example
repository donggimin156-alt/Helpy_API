# .env.example
# ============================================================
# 환경 변수 예시 파일 — 실제 값은 .env 에 저장하고 gitignore 처리한다.
#
# 사용법:
#   1. 이 파일을 복사해 .env 로 저장한다.
#      cp .env.example .env
#   2. 실제 값으로 채운다.
#   3. .env 는 절대 git 에 커밋하지 않는다.
#
# CI(Jenkins) 에서는 Jenkins Credentials 에 등록하고
# withCredentials 로 OS 환경변수로 주입한다.
# settings.py 가 .env 우선 + OS 환경변수 fallback 으로 동작하므로
# 로컬/CI 동일한 코드로 동작한다.
# ============================================================

# ── API 인증 토큰 ────────────────────────────────────────────
# 로그인 후 발급받은 Bearer 토큰을 입력한다.
# conftest.py 의 auth_client fixture 가 Authorization: Bearer <TOKEN> 헤더에 주입한다.
API_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.여기에_실제_토큰_입력

# ── 실행 환경 ────────────────────────────────────────────────
# staging | production
# production 으로 설정하면 conftest 가 destructive 테스트를 자동 차단한다.
ENVIRONMENT=staging
